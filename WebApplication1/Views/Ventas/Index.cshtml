@model IEnumerable<WebApplication1.Models.Venta>

@{
    ViewData["Title"] = "Ventas";
}

<h1>Ventas</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Crear Venta</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Fecha</th>
            <th>Cliente</th>
            <th>Documento</th>
            <th>Productos</th>
            <th>Total</th>
            <th>Estado</th>
            <th>Método Pago</th>
            <th></th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.FechaVenta</td>

                <td>@item.ClienteNombre</td>

                <td>@item.ClienteDocumento</td>

                <td>

                    @if (item.Detalles != null && item.Detalles.Any())
                    {
                        <ul>

                            @foreach (var d in item.Detalles)
                            {
                                <li>
                                    @d.Producto?.Name (Cant: @d.Cantidad)
                                </li>
                            }

                        </ul>
                    }

                </td>

                <td>$ @item.Total.ToString("F2")</td>

                <td>@item.Estado</td>

                <td>@item.MetodoPago</td>

                <td>

                    <a asp-action="Edit" asp-route-id="@item.Id">Editar</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Detalles</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Eliminar</a>

                </td>

            </tr>
        }

    </tbody>
</table>