@model IEnumerable<WebApplication1.Models.Category>

@{
    ViewData["Title"] = "Categorías";
}

<style>
    .product-list {
        list-style: none;
        padding-left: 0;
        margin-bottom: 0;
    }

        .product-list li {
            padding: 2px 0;
        }

    .action-links a {
        margin-right: 10px;
        text-decoration: none;
        color: #007bff;
    }

        .action-links a:hover {
            text-decoration: underline;
        }

        .action-links a.delete {
            color: #dc3545;
        }

    .create-buttons {
        margin: 20px 0;
    }

        .create-buttons .btn {
            margin-right: 10px;
        }

    .header-links {
        margin-bottom: 20px;
        padding: 10px 0;
        border-bottom: 1px solid #dee2e6;
    }

        .header-links a {
            margin-right: 20px;
            text-decoration: none;
            color: #6c757d;
        }

            .header-links a:hover {
                color: #007bff;
            }

            .header-links a.active {
                color: #007bff;
                font-weight: bold;
            }

    h1, h2 {
        color: #343a40;
    }

    table {
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        width: 100%;
        border-collapse: collapse;
    }

    thead {
        background-color: #007bff;
        color: white;
    }

    th, td {
        padding: 12px;
        text-align: left;
        border-bottom: 1px solid #ddd;
    }

    tr:hover {
        background-color: #f5f5f5;
    }
</style>

<div class="header-links">
    <a href="@Url.Action("Index", "Home")" class="active">Home</a>
    <a href="@Url.Action("Privacy", "Home")">Privacy</a>
</div>

<h1>Index</h1>

<div class="create-buttons">
    <a asp-action="Create" class="btn btn-primary">Crear categoría</a>
    <a asp-controller="Products" asp-action="Create" class="btn btn-success">Crear producto</a>
</div>

<h2>Categorías</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nombre</th>
            <th>Productos</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CategoryId</td>
                <td>@item.Name</td>
                <td>
                    @if (item.Products != null && item.Products.Any())
                    {
                        <ul class="product-list">
                            @foreach (var product in item.Products)
                            {
                                <li>- @product.Name ($ @product.Price.ToString("F2"))</li>
                            }
                        </ul>
                    }
                </td>
                <td class="action-links">
                    <a asp-action="Edit" asp-route-id="@item.CategoryId">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.CategoryId" class="delete">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@* Mostrar todos los productos al final *@
@{
    var allProducts = Model.SelectMany(c => c.Products ?? new List<WebApplication1.Models.Product>()).ToList();
}

@if (allProducts.Any())
{
    <div style="margin-top: 20px;">
        @foreach (var product in allProducts)
        {
            <div>- @product.Name ($ @product.Price.ToString("F2"))</div>
        }
    </div>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}